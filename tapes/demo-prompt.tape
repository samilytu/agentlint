# Agent Lint — prompt command demo
# Records: agent-lint prompt generating copy-paste prompt for IDE

Output docs/screenshots/demo-prompt.gif

Set Shell "powershell"
Set FontSize 15
Set Width 96
Set Height 28
Set Theme "Catppuccin Mocha"
Set Framerate 24
Set PlaybackSpeed 0.8
Set TypingSpeed 60ms
Set Padding 16

Type "node packages/cli/dist/index.js prompt"
Sleep 400ms
Enter
Sleep 3s

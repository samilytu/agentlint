# Agent Lint — init command demo
# Records: agent-lint init detecting IDEs and creating MCP configs

Output docs/screenshots/demo-init.gif

Set Shell "powershell"
Set FontSize 16
Set Width 80
Set Height 24
Set Theme "Catppuccin Mocha"
Set Framerate 24
Set TypingSpeed 60ms

Type "node packages/cli/dist/index.js init"
Sleep 400ms
Enter
Sleep 3s

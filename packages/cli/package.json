{
  "name": "@agent-lint/cli",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI for AI agent context artifact orchestration. Auto-detect IDEs, scan workspaces, generate fix reports. No LLM, no database.",
  "author": "Agent Lint Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/bsamilozturk/agentlint.git",
    "directory": "packages/cli"
  },
  "homepage": "https://gitlab.com/bsamilozturk/agentlint#readme",
  "bugs": {
    "url": "https://gitlab.com/bsamilozturk/agentlint/-/issues"
  },
  "keywords": [
    "cli",
    "ai-agents",
    "context-artifacts",
    "orchestrator",
    "agents-md",
    "claude-md",
    "lint",
    "ci-cd"
  ],
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "agent-lint": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@agent-lint/core": "workspace:*",
    "@agent-lint/shared": "workspace:*",
    "typescript": "^5.0.0"
  }
}

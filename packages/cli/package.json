{
  "name": "@agent-lint/cli",
  "version": "0.5.1",
  "type": "module",
  "license": "MIT",
  "description": "CLI for keeping AGENTS.md, CLAUDE.md, rules, skills, workflows, and plans structured, current, and codebase-aware.",
  "author": "Agent Lint Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/bsamilozturk/agentlint.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/samilytu/agentlint#readme",
  "bugs": {
    "url": "https://github.com/samilytu/agentlint/issues"
  },
  "keywords": [
    "cli",
    "agent-lint",
    "agentlint",
    "agents-md",
    "mcp",
    "claude-code",
    "cursor",
    "windsurf",
    "codex",
    "vscode",
    "context-files"
  ],
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "agent-lint": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "clipboardy": "5.3.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "19",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@agent-lint/core": "workspace:*",
    "@agent-lint/shared": "workspace:*",
    "@types/react": "^19.2.14",
    "typescript": "^5.0.0"
  }
}

{
  "name": "@agent-lint/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI for AI agent context artifact analysis and quality scoring",
  "files": ["dist/", "LICENSE"],
  "bin": {
    "agent-lint": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@agent-lint/core": "workspace:*",
    "@agent-lint/shared": "workspace:*",
    "typescript": "^5.0.0"
  }
}

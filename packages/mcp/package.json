{
  "name": "@agent-lint/mcp",
  "version": "0.4.1",
  "type": "module",
  "license": "MIT",
  "description": "Read-only MCP server for keeping AGENTS.md, CLAUDE.md, rules, skills, workflows, and plans structured, current, and codebase-aware.",
  "author": "Agent Lint Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/bsamilozturk/agentlint.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/samilozturk/agentlint#readme",
  "bugs": {
    "url": "https://github.com/samilozturk/agentlint/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "agent-lint",
    "agentlint",
    "agents-md",
    "claude-code",
    "cursor",
    "windsurf",
    "codex",
    "vscode",
    "model-context-protocol"
  ],
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "agent-lint-mcp": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@agent-lint/shared": "workspace:*",
    "@agent-lint/core": "workspace:*",
    "typescript": "^5.0.0"
  }
}

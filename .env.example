DATABASE_URL=file:./sqlite.db
LLM_PROVIDER=gemini
ANALYSIS_V2_ENABLED=true
JUDGE_PROVIDER_TIMEOUT_MS=12000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-001
GEMINI_GEMMA_MODEL=
GEMINI_MAX_RETRIES=3
GEMINI_INITIAL_DELAY_MS=2000
GEMINI_MODEL_CACHE_TTL_MS=600000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000
CONTEXT_BUNDLE_CHAR_BUDGET=120000

# MCP server
MCP_SERVER_NAME=agentlint-mcp
MCP_SERVER_VERSION=0.1.0
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3333
# Set true for clients that do not preserve Mcp-Session-Id across calls.
MCP_HTTP_STATELESS=false
MCP_PUBLIC_BASE_URL=
MCP_REQUIRE_AUTH=true
MCP_BEARER_TOKENS=dev-local-token:*
MCP_ENFORCE_TOOL_SCOPES=true
# Set true only when behind a trusted reverse proxy and you want to use x-forwarded-for for rate limiting.
MCP_TRUST_PROXY=false
MCP_RATE_LIMIT_MAX_REQUESTS=120
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_MAX_BODY_BYTES=1000000
MCP_REQUEST_TIMEOUT_MS=30000
MCP_MAX_CONCURRENT_REQUESTS=64
MCP_SESSION_TTL_MS=1800000
MCP_SESSION_SWEEP_INTERVAL_MS=60000
MCP_ALLOWED_HOSTS=127.0.0.1,localhost
# Optional: true enables workspace scan tool. In stdio mode default is enabled unless set to false.
# In remote mode this stays disabled unless explicitly set to true.
# MCP_ENABLE_WORKSPACE_SCAN=

# Optional OAuth metadata for production auth migration
MCP_SUPPORTED_SCOPES=analyze,validate,patch
MCP_OAUTH_ISSUER=
MCP_OAUTH_AUTHORIZATION_ENDPOINT=
MCP_OAUTH_TOKEN_ENDPOINT=
MCP_OAUTH_JWKS_URI=
